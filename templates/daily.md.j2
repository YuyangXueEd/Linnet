---
layout: default
title: "{{ date }} Daily Digest"
parent: Daily Digest
nav_exclude: true
date: {{ date }}
---

{% set scoring_model = meta.get('scoring_model') %}
{% set summarization_model = meta.get('summarization_model') %}

<div class="report-shell">
  <section class="report-hero">
    <div class="landing-kicker">Daily issue</div>
    <h1>{{ date }} Daily Digest</h1>
    <p>
      Your latest auto-published briefing across the sources enabled in
      <code>config/sources.yaml</code>.
    </p>

    {% if scoring_model and summarization_model and scoring_model != summarization_model %}
    <div class="report-note">
      <strong>Generated on {{ generated_at[:10] }}</strong>
      Scoring model: {{ scoring_model }} · Summary model: {{ summarization_model }}
    </div>
    {% else %}
    <div class="report-note">
      <strong>Generated on {{ generated_at[:10] }}</strong>
      Model: <code>{{ meta.llm_model }}</code>
    </div>
    {% endif %}

    <div class="report-stat-grid">
      <div class="report-stat">
        <strong>{{ papers|length }}</strong>
        <span>Papers</span>
      </div>
      <div class="report-stat">
        <strong>{{ hacker_news|length }}</strong>
        <span>HN stories</span>
      </div>
      <div class="report-stat">
        <strong>{{ github_trending|length }}</strong>
        <span>Trending repos</span>
      </div>
      <div class="report-stat">
        <strong>{{ jobs|length + supervisor_updates|length + weather|length }}</strong>
        <span>Other sections</span>
      </div>
    </div>

    {% if meta.get('papers_after_keyword_filter') is not none %}
    <div class="report-note">
      {{ meta.get('papers_after_keyword_filter') }} candidates passed keyword filtering
    </div>
    {% endif %}

    <div class="report-link-row">
      <a class="landing-button secondary" href="/">Home</a>
      <a class="landing-button secondary" href="/daily/">Daily archive</a>
      <a class="landing-button secondary" href="/weekly/">Weekly rollup</a>
      <a class="landing-button secondary" href="/monthly/">Monthly overview</a>
    </div>
  </section>
</div>

{% for sec in sections_ordered %}
{% include "extensions/" + sec.key + "/head.html.j2" ignore missing %}
{% endfor %}

<aside class="daily-nav-panel" aria-label="Page navigation">
  <div class="daily-nav-title">Quick Nav</div>
  <ul>
  {% for sec in sections_ordered %}{% if sec["items"] %}
    <li>
      <a href="#{{ sec.key }}">{{ sec.icon }} {{ sec.title }}</a>
      {% include "extensions/" + sec.key + "/nav.md.j2" ignore missing %}
    </li>
  {% endif %}{% endfor %}
  </ul>
</aside>

<details class="daily-nav-mobile">
  <summary><strong>Quick Nav</strong></summary>
  <ul>
  {% for sec in sections_ordered %}{% if sec["items"] %}
    <li>
      <a href="#{{ sec.key }}">{{ sec.icon }} {{ sec.title }}</a>
      {% include "extensions/" + sec.key + "/nav.md.j2" ignore missing %}
    </li>
  {% endif %}{% endfor %}
  </ul>
</details>

{% for sec in sections_ordered %}
{% include "extensions/" + sec.key + "/template.md.j2" ignore missing %}
{% endfor %}

<div class="report-link-row report-link-row--footer">
  <a class="landing-button secondary" href="/">Home</a>
  <a class="landing-button secondary" href="/weekly/">Weekly</a>
  <a class="landing-button secondary" href="/monthly/">Monthly</a>
</div>
