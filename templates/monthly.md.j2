---
layout: default
title: "{{ period }} Monthly Overview"
parent: Monthly Overview
nav_exclude: true
---

{% set rollup_summary = summary|default(summary_zh, true)|default('', true) %}

<div class="report-shell">
  <section class="report-hero">
    <div class="landing-kicker">Monthly overview</div>
    <h1>{{ period }} Monthly Overview</h1>
    <p>
      A broader trend view built from {{ daily_refs|length }} daily snapshots across the month.
    </p>

    <div class="report-stat-grid">
      <div class="report-stat">
        <strong>{{ top_papers|length }}</strong>
        <span>Papers in rollup</span>
      </div>
      <div class="report-stat">
        <strong>{{ new_jobs|length }}</strong>
        <span>Jobs tracked</span>
      </div>
      <div class="report-stat">
        <strong>{{ keyword_frequency|length }}</strong>
        <span>Keywords counted</span>
      </div>
      <div class="report-stat">
        <strong>{{ daily_refs|length }}</strong>
        <span>Days covered</span>
      </div>
    </div>

    <div class="report-link-row">
      <a class="landing-button secondary" href="/">Home</a>
      <a class="landing-button secondary" href="/daily/">Daily archive</a>
      <a class="landing-button secondary" href="/weekly/">Weekly rollup</a>
    </div>
  </section>

  <section class="report-panel">
    <div class="report-panel-kicker">Summary</div>
    <h2>What stood out this month</h2>
    <div class="report-summary" markdown="1">
{{ rollup_summary }}
    </div>
  </section>

  <section class="report-panel">
    <div class="report-panel-kicker">Top papers</div>
    <h2>Highest-scoring papers</h2>
    <div class="report-item-grid">
      {% for p in top_papers[:20] %}
      <article class="report-item-card">
        <div class="report-item-kicker">Top paper #{{ loop.index }}</div>
        <h3><a href="{{ p.url }}">{{ p.title }}</a></h3>
        <p class="report-item-meta">Score {{ "%.1f"|format(p.score) }}/10</p>
        <p>{{ p.get('abstract_zh') or p.get('abstract') }}</p>
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="report-panel">
    <div class="report-panel-kicker">Keyword heat</div>
    <h2>Top keywords</h2>
    <div class="report-tag-grid">
      {% for kw, count in (keyword_frequency.items() | list | sort(attribute=1, reverse=True))[:10] %}
      <span class="report-tag">{{ kw }} · {{ count }}</span>
      {% endfor %}
      {% if not keyword_frequency %}
      <span class="report-tag">No keyword frequency data captured this month</span>
      {% endif %}
    </div>
  </section>

  {% if new_jobs %}
  <section class="report-panel">
    <div class="report-panel-kicker">Jobs</div>
    <h2>Open roles this month</h2>
    <div class="report-list-compact">
      {% for j in new_jobs %}
      <article class="report-list-row">
        <h3><a href="{{ j.url }}">{{ j.title }}</a></h3>
        <p>{{ j.institution or 'Unknown institution' }}</p>
      </article>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</div>

<div class="report-link-row report-link-row--footer">
  <a class="landing-button secondary" href="/">Home</a>
  <a class="landing-button secondary" href="/daily/">Daily</a>
  <a class="landing-button secondary" href="/weekly/">Weekly</a>
</div>
