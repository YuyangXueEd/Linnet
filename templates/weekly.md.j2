---
layout: default
title: "{{ period }} Weekly Rollup"
parent: Weekly Rollup
nav_exclude: true
---

{% set rollup_summary = summary|default(summary_zh, true)|default('', true) %}

<div class="report-shell">
  <section class="report-hero">
    <div class="landing-kicker">Weekly rollup</div>
    <h1>{{ period }} Weekly Rollup</h1>
    <p>
      Covering {{ daily_refs[0] }} to {{ daily_refs[-1] }} across {{ daily_refs|length }} days of saved daily data.
    </p>

    <div class="report-stat-grid">
      <div class="report-stat">
        <strong>{{ top_papers|length }}</strong>
        <span>Papers selected</span>
      </div>
      <div class="report-stat">
        <strong>{{ new_jobs|length }}</strong>
        <span>Jobs found</span>
      </div>
      <div class="report-stat">
        <strong>{{ trending_keywords[:5]|length }}</strong>
        <span>Top keywords</span>
      </div>
      <div class="report-stat">
        <strong>{{ daily_refs|length }}</strong>
        <span>Daily snapshots</span>
      </div>
    </div>

    <div class="report-link-row">
      <a class="landing-button secondary" href="/">Home</a>
      <a class="landing-button secondary" href="/daily/">Daily archive</a>
      <a class="landing-button secondary" href="/monthly/">Monthly overview</a>
    </div>
  </section>

  <section class="report-panel">
    <div class="report-panel-kicker">Trend analysis</div>
    <h2>What changed this week</h2>
    <div class="report-summary" markdown="1">
{{ rollup_summary }}
    </div>
  </section>

  <section class="report-panel">
    <div class="report-panel-kicker">Signals</div>
    <h2>At a glance</h2>
    <div class="report-tag-grid">
      {% for kw in trending_keywords[:10] %}
      <span class="report-tag">{{ kw }}</span>
      {% endfor %}
      {% if not trending_keywords %}
      <span class="report-tag">No keyword spikes captured this week</span>
      {% endif %}
    </div>
  </section>

  <section class="report-panel">
    <div class="report-panel-kicker">Top papers</div>
    <h2>Best papers this week</h2>
    <div class="report-item-grid">
      {% for p in top_papers[:10] %}
      <article class="report-item-card">
        <div class="report-item-kicker">Top paper #{{ loop.index }}</div>
        <h3><a href="{{ p.url }}">{{ p.title }}</a></h3>
        <p class="report-item-meta">Score {{ "%.1f"|format(p.score) }}/10</p>
        <p>{{ p.get('abstract_zh') or p.get('abstract') }}</p>
      </article>
      {% endfor %}
    </div>
  </section>

  {% if new_jobs %}
  <section class="report-panel">
    <div class="report-panel-kicker">Jobs</div>
    <h2>Open roles this week</h2>
    <div class="report-list-compact">
      {% for j in new_jobs %}
      <article class="report-list-row">
        <h3><a href="{{ j.url }}">{{ j.title }}</a></h3>
        <p>{{ j.institution or 'Unknown institution' }} · Deadline: {{ j.deadline or 'N/A' }}</p>
      </article>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</div>

<div class="report-link-row report-link-row--footer">
  <a class="landing-button secondary" href="/">Home</a>
  <a class="landing-button secondary" href="/daily/">Daily</a>
  <a class="landing-button secondary" href="/monthly/">Monthly</a>
</div>
